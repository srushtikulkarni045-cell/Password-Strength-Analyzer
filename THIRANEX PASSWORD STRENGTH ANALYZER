import sqlite3
import hashlib
import random
import string


# -------------------------
# Database Functions
# -------------------------

def create_database():
    conn = sqlite3.connect("password_history.db")
    cursor = conn.cursor()

    cursor.execute("""
    CREATE TABLE IF NOT EXISTS old_passwords(
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        password_hash TEXT
    )
    """)

    conn.commit()
    conn.close()


def hash_password(password):
    return hashlib.sha256(password.encode()).hexdigest()


def password_used_before(password):
    conn = sqlite3.connect("password_history.db")
    cursor = conn.cursor()

    password_hash = hash_password(password)

    cursor.execute(
        "SELECT * FROM old_passwords WHERE password_hash=?",
        (password_hash,)
    )

    result = cursor.fetchone()

    conn.close()

    return result is not None


def save_password(password):
    conn = sqlite3.connect("password_history.db")
    cursor = conn.cursor()

    password_hash = hash_password(password)

    cursor.execute(
        "INSERT INTO old_passwords(password_hash) VALUES(?)",
        (password_hash,)
    )

    conn.commit()
    conn.close()


# -------------------------
# Password Analysis
# -------------------------

def load_common_passwords():
    try:
        with open("common_passwords.txt", "r") as file:
            return [line.strip() for line in file]
    except FileNotFoundError:
        return []


def analyze_password(password):
    score = 0
    remarks = []

    common_passwords = load_common_passwords()

    if len(password) >= 8:
        score += 1
    else:
        remarks.append("Password should contain at least 8 characters.")

    if any(char.islower() for char in password):
        score += 1
    else:
        remarks.append("Add lowercase letters.")

    if any(char.isupper() for char in password):
        score += 1
    else:
        remarks.append("Add uppercase letters.")

    if any(char.isdigit() for char in password):
        score += 1
    else:
        remarks.append("Add numbers.")

    special_chars = "!@#$%^&*()-_=+[]{};:,.<>?/"

    if any(char in special_chars for char in password):
        score += 1
    else:
        remarks.append("Add special characters.")

    if password.lower() in common_passwords:
        remarks.append("This is a commonly used password.")
        score -= 2

    if password_used_before(password):
        remarks.append("This password has been used before.")
        score -= 1

    if score <= 2:
        strength = "Weak"
    elif score <= 4:
        strength = "Medium"
    else:
        strength = "Strong"

    return strength, remarks


# -------------------------
# Password Suggestion
# -------------------------

def generate_strong_password():
    uppercase = random.choice(string.ascii_uppercase)
    lowercase = random.choice(string.ascii_lowercase)
    digit = random.choice(string.digits)
    special = random.choice("!@#$%^&*")

    remaining = ''.join(
        random.choices(
            string.ascii_letters +
            string.digits +
            "!@#$%^&*",
            k=8
        )
    )

    password = uppercase + lowercase + digit + special + remaining

    password_list = list(password)
    random.shuffle(password_list)

    return ''.join(password_list)


# -------------------------
# Main Program
# -------------------------

def main():
    create_database()

    print("=" * 50)
    print("PASSWORD STRENGTH ANALYZER")
    print("=" * 50)

    password = input("Enter a password: ")

    strength, remarks = analyze_password(password)

    print("\nPassword Strength:", strength)

    if remarks:
        print("\nSuggestions:")
        for item in remarks:
            print("-", item)

    if strength != "Strong":
        print("\nSuggested Strong Password:")
        print(generate_strong_password())

    choice = input(
        "\nDo you want to save this password in history? (y/n): "
    )

    if choice.lower() == "y":
        save_password(password)
        print("Password saved successfully.")

    print("\nProgram Finished.")


if __name__ == "__main__":
    main()
